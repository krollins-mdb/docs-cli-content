  "codeBlocks": [
    {
      "language": "javascript",
      "section": "Overview",
      "content": "const myDB = client.db(\"myDB\");\nconst myColl = myDB.collection(\"fruits\");\n\nawait myColl.insertMany([\n  { \"_id\": 1, \"name\": \"apples\", \"qty\": 5, \"rating\": 3 },\n  { \"_id\": 2, \"name\": \"bananas\", \"qty\": 7, \"rating\": 1, \"color\": \"yellow\" },\n  { \"_id\": 3, \"name\": \"oranges\", \"qty\": 6, \"rating\": 2 },\n  { \"_id\": 4, \"name\": \"avocados\", \"qty\": 3, \"rating\": 5 },\n]);",
      "tokenEstimate": 144
    },
    {
      "language": "javascript",
      "section": "Literal Value Queries",
      "content": "const query = { \"name\": \"apples\" };\nconst cursor = myColl.find(query);\nfor await (const doc of cursor) {\n  console.dir(doc);\n}",
      "tokenEstimate": 35
    },
