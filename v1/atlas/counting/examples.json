      "section": "Syntax",
      "content": "{\n  \"$searchMeta\"|\"$search\": {\n    \"index\": \"<index name>\", // optional, defaults to \"default\"\n    \"<operator>\": {\n      <operator-specifications>\n    },\n    \"count\": {\n      \"type\": \"lowerBound\"|\"total\",\n      \"threshold\": <number-of-documents> //optional\n    }\n  }\n}",
