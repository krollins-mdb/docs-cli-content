  "codeBlocks": [
    {
      "language": "json",
      "section": "Syntax",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": true|false | {\n        \"typeSet\": \"<typeset-name>\"\n    },\n    \"fields\": {\n      \"<field-name>\": {\n        \"type\": \"<field-type>\",\n        ...\n      },\n      ...\n    }\n  },\n  \"typeSets\": [\n    {\n      \"name\": \"<typeset-name>\",\n      \"types\": [\n        {\n          \"type\": \"<field-type>\",\n          ...\n        },\n        ...\n      ]\n    },\n    ...\n  ]\n}",
      "tokenEstimate": 105
    },
    {
      "language": "json",
      "section": "Enable Default typeSet",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": false\n  }\n}",
      "tokenEstimate": 16
    },
    {
      "language": "json",
      "section": "Configure a typeSet",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": {\n      \"typeSet\": \"<typeset-name>\"\n    },\n    \"fields\": {\n      \"<field-name>\": {\n        \"type\": \"<field-type>\",\n        ...\n      },\n      ...\n    }\n  },\n  \"typeSets\": [\n    {\n      \"name\": \"<typeset-name>\",\n      \"types\": [\n        {\n          \"type\": \"<field-type>\"\n        },\n        ...\n      ]\n    },\n    ...\n  ]\n}\n",
      "tokenEstimate": 99
    },
    {
      "language": "json",
      "section": "Static Mappings",
      "content": "{\n  \"mappings\": { \n    \"dynamic\": true|false, \n    \"fields\": { \n      \"<field-name>\": {\n        \"type\": \"<field-type>\",\n        ...\n      },\n      ...  \n    }\n  }\n}",
      "tokenEstimate": 50
    },
    {
      "language": "json",
      "section": "Static Mappings",
      "content": "{\n  \"mappings\": { \n    \"dynamic\": true|false | {\n      \"typeSet\": \"<type-set-name>\"\n    }, \n    \"fields\": { \n      \"<field-name>\": [\n        {\n          \"type\": \"<field-type>\",\n          ...\n        },\n        {\n          \"type\": \"<field-type>\",\n          ...\n        },\n        ...\n      ],\n      ...  \n    }\n  }.\n  \"typeSets\": [\n    {\n      \"name\": \"<typeset-name>\",\n      \"types\": [\n        {\n          \"type\": \"<field-type>\"\n        },\n        ...\n      ]\n    },\n    ...\n  ]\n}",
      "tokenEstimate": 128
    },
    {
      "language": "json",
      "section": "Dynamic Mapping Examples",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": {\n      \"typeSet\": \"movieFieldTypes\"\n    }\n  },\n  \"typeSets\": [\n    {\n      \"name\": \"movieFieldTypes\",\n      \"types\": [\n        {\n          \"type\": \"number\"\n        },\n        {\n          \"type\": \"autocomplete\",\n          \"analyzer\": \"lucene.standard\",\n          \"tokenization\": \"edgeGram\",\n          \"minGrams\": 4,\n          \"maxGrams\": 10\n        }\n      ]\n    }\n  ]\n}",
      "tokenEstimate": 114
    },
    {
      "language": "json",
      "section": "Dynamic Mapping Examples",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": {\n      \"typeSet\": \"first\"\n    },\n    \"fields\": {\n      \"awards\": {\n        \"type\": \"document\",\n        \"dynamic\": {\n          \"typeSet\": \"second\"\n        }\n      }\n    }\n  },\n  \"typeSets\": [\n    {\n      \"name\": \"first\",\n      \"types\": [\n        {\n          \"type\": \"token\"\n        },\n        {\n          \"type\": \"autocomplete\"\n        }\n      ]\n    },\n    {\n      \"name\": \"second\",\n      \"types\": [\n        {\n          \"type\": \"number\"\n        }\n      ]\n    }\n  ]\n}",
      "tokenEstimate": 139
    },
    {
      "language": "json",
      "section": "Dynamic Mapping Examples",
      "content": "{\n  \"analyzer\": \"lucene.standard\",\n  \"searchAnalyzer\": \"lucene.standard\",\n  \"mappings\": {\n    \"dynamic\": {\n      \"typeSet\": \"indexedTypes\"\n    },\n    \"fields\": {\n      \"plot\": []\n    }\n  },\n  \"typeSets\": [\n    {\n      \"name\": \"indexedTypes\",\n      \"types\": [\n        {\n          \"type\": \"token\"\n        },\n        {\n          \"type\": \"number\"\n        }\n      ]\n    }\n  ]\n}",
      "tokenEstimate": 107
    },
    {
      "language": "json",
      "section": "Static Mapping Example",
      "content": "{\n  \"analyzer\": \"lucene.standard\",\n  \"searchAnalyzer\": \"lucene.standard\",\n  \"mappings\": {\n    \"dynamic\": false,\n    \"fields\": {\n      \"awards\": {\n        \"type\": \"document\",\n        \"fields\": {\n          \"wins\": {\n            \"type\": \"number\"\n          },\n          \"nominations\": {\n            \"type\": \"number\",\n            \"representation\": \"int64\"\n          },\n          \"text\": {\n            \"type\": \"string\",\n            \"analyzer\": \"lucene.english\",\n            \"ignoreAbove\": 255\n          }\n        }\n      },\n      \"title\": {\n        \"type\": \"string\",\n        \"analyzer\": \"lucene.whitespace\",\n        \"multi\": {\n          \"mySecondaryAnalyzer\": {\n            \"type\": \"string\",\n            \"analyzer\": \"lucene.french\"\n          }\n        }\n      },\n      \"genres\": {\n        \"type\": \"string\",\n        \"analyzer\": \"lucene.standard\"\n      }\n    }\n  }\n}",
