    {
      "language": "json",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "{\n  \"$source\": {\n    \"connectionName\": \"sample_stream_solar\"\n  }\n}",
      "tokenEstimate": 20
    },
    {
      "language": "json",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "{\n  \"$tumblingWindow\": {\n    \"interval\": {\n       \"size\": 10,\n       \"unit\": \"second\"\n    },\n    \"pipeline\": [ {\n      \"$group\": {\n        \"_id\": \"$group_id\",\n        \"max_temp\": {\n          \"$max\": \"$obs.temp\"\n        },\n        \"max_watts\": {\n          \"$max\": \"$obs.watts\"\n        },\n        \"min_watts\": {\n          \"$min\": \"$obs.watts\"\n        },\n        \"avg_watts\": {\n          \"$avg\": \"$obs.watts\"\n        }\n      }\n    }]\n  }\n}",
      "tokenEstimate": 125
    },
    {
      "language": "json",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "{\n  \"$merge\": {\n    \"into\": {\n       \"connectionName\": \"mongodb1\",\n       \"db\": \"solarDb\",\n       \"coll\": \"solarColl\"\n    }\n  }\n}",
      "tokenEstimate": 43
    },
    {
      "language": "json",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "{\n  \"name\": \"solarDemo\",\n  \"pipeline\": [\n    {\n      \"$source\": {\n        \"connectionName\": \"sample_stream_solar\"\n      }\n    },\n    {\n      \"$tumblingWindow\": {\n        \"interval\": {\n          \"size\": 10,\n          \"unit\": \"second\"\n        },\n        \"pipeline\": [\n          {\n            \"$group\": {\n              \"_id\": \"$group_id\",\n              \"max_temp\": {\n                \"$max\": \"$obs.temp\"\n              },\n              \"max_watts\": {\n                \"$max\": \"$obs.watts\"\n              },\n              \"min_watts\": {\n                \"$min\": \"$obs.watts\"\n              },\n              \"avg_watts\": {\n                \"$avg\": \"$obs.watts\"\n              }\n            }\n          }\n        ]\n      }\n    },\n    {\n      \"$merge\": {\n        \"into\": {\n          \"connectionName\": \"mongodb1\",\n          \"db\": \"Cluster0\",\n          \"coll\": \"solarColl\"\n        },\n        \"parallelism\":16,\n      }\n    }\n  ]\n}",
      "tokenEstimate": 221
    },
    {
      "language": "sh",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "mongosh \"mongodb://<atlas-stream-processing-url>/\"\n--tls --authenticationDatabase admin --username <username>\n--password <password>",
      "tokenEstimate": 29
    },
    {
      "language": "sh",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "let s = {\n  $source: {\n    connectionName: \"sample_stream_solar\"\n  }\n}",
      "tokenEstimate": 22
    },
    {
      "language": "sh",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "let g = {\n  $group: {\n    _id: \"$group_id\",\n    max_temp: {\n      $max: \"$obs.temp\"\n    },\n    avg_watts: {\n       $avg: \"$obs.watts\"\n    },\n    max_watts: {\n      $max: \"$obs.watts\"\n    },\n    min_watts: {\n      $min: \"$obs.watts\"\n    }\n  }\n}",
      "tokenEstimate": 86
    },
    {
      "language": "sh\n :copyable: true",
      "section": "Step 4: Create a persistent stream processor.",
      "content": " let t = {\n   $tumblingWindow: {\n     interval: {\n       size: NumberInt(10),\n       unit: \"second\"\n     },\n     pipeline: [g]\n  }\n}",
      "tokenEstimate": 40
    },
    {
      "language": "sh",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "let m = {\n  $merge: {\n    into: {\n      connectionName: \"mongodb1\",\n      db: \"solarDb\",\n      coll: \"solarColl\"\n    }\n  }\n}",
      "tokenEstimate": 42
    },
    {
      "language": "sh",
      "section": "Step 4: Create a persistent stream processor.",
      "content": "sp.createStreamProcessor(\"solarDemo\", [s, t, m])",
      "tokenEstimate": 16
    },
    {
      "language": "sh",
      "section": "Step 5: Start the stream processor.",
      "content": "sp.solarDemo.start()",
      "tokenEstimate": 6
    },
    {
      "language": "sh",
      "section": "Step 6: Verify the output of the stream processor.",
      "content": "sp.solarDemo.stats()",
      "tokenEstimate": 6
    },
    {
