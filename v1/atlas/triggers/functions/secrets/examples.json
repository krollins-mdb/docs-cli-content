  "codeBlocks": [
    {
      "language": "shell",
      "section": "Step 1: Authenticate a MongoDB  User",
      "content": "appservices login --api-key=\"<API KEY>\" --private-api-key=\"<PRIVATE KEY>\"",
      "tokenEstimate": 18
    },
    {
      "language": "shell",
      "section": "Step 2: Pull Your App's Latest Configuration Files",
      "content": "appservices pull --remote=<App ID>",
      "tokenEstimate": 9
    },
    {
      "language": "shell",
      "section": "Step 3: Create a New Secret",
      "content": "appservices secrets create --app=<Your App ID> \\\n  --name=\"<Secret Name>\" \\\n  --value=\"<Secret Value>\"",
      "tokenEstimate": 27
    },
    {
      "language": "shell",
      "section": "Step 4: Deploy Your Changes",
      "content": "appservices push",
      "tokenEstimate": 3
    },
    {
      "language": "shell",
      "section": "View Secrets",
      "content": "appservices secrets list --app=<Your App ID>",
      "tokenEstimate": 11
    },
    {
      "language": "shell",
      "section": "Update a Secret",
      "content": "appservices secrets update --app=<Your App ID> \\\n  --secret=\"<Secret ID or Name>\" \\\n  --name=\"<Updated Secret Name>\" \\\n  --value=\"<Updated Value>\"",
      "tokenEstimate": 38
    },
    {
      "language": "shell",
      "section": "Delete a Secret",
      "content": "appservices secrets delete --app=<Your App ID> --secret=<Secret ID>",
      "tokenEstimate": 17
    },
    {
      "language": "bash",
      "section": "Delete a Secret",
      "content": "appservices secrets delete --app=<Your App ID> \\\n--secret=some-api-key,609af850b78eca4a8db4303f,another-key",
      "tokenEstimate": 35
    }
  ]
