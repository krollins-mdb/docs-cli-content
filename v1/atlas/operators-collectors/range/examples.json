      "language": "javascript",
      "section": "Syntax",
      "content": "{\n    \"$search\": {\n       \"index\": <index name>, // optional, defaults to \"default\"\n       \"range\": {\n          \"path\": \"<field-to-search>\",\n          \"gt | gte\": <value-to-search>,\n          \"lt | lte\": <value-to-search>,\n          \"score\": <score-options>\n       }\n    }\n}",
      "tokenEstimate": 73
