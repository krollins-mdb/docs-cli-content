    {
      "language": "javascript",
      "section": "Syntax",
      "content": "{\n  \"$searchMeta\"|\"$search\": {\n    \"index\": <index name>, // optional, defaults to \"default\"\n    \"facet\": {\n      \"operator\": {\n        <operator-specifications>\n      },\n      \"facets\": {\n        <facet-definitions>\n      }\n    },\n    \"returnScope\": {\n      \"path\": \"<embedded-documents-field-to-query>\"\n    },\n    \"returnStoredSource\": true\n  }\n}",
      "tokenEstimate": 91
    },
    {
      "language": "json",
      "section": "Syntax",
      "content": "{\n  \"$searchMeta\": {\n    \"facet\":{\n      \"operator\": {\n        <operator-specification>\n      },\n      \"facets\": {\n        \"<facet-name>\" : {\n          \"type\" : \"string\",\n          \"path\" : \"<field-path>\",\n          \"numBuckets\" : <number-of-categories>,\n        }\n      }\n    }\n  }\n}",
      "tokenEstimate": 75
    },
    {
      "language": "json",
      "section": "Example",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": false,\n    \"fields\": {\n      \"genres\": {\n        \"type\": \"token\"\n      },\n      \"year\": {\n        \"type\": \"number\"\n      }\n    }\n  }\n}",
      "tokenEstimate": 51
