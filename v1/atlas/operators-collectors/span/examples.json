  "codeBlocks": [
    {
      "language": "javascript",
      "section": "Syntax",
      "content": "{\n   $search: {\n     \"index\": <index name>, // optional, defaults to \"default\"\n     \"span\": {\n       \"term\" | <positional-operator>\": {\n         <operator-specification>\n       }\n     }\n   }\n}",
      "tokenEstimate": 52
    },
    {
      "language": "json",
      "section": "Syntax",
      "content": "\"term\": {\n  \"path\": \"<path-to-field>\",\n  \"query\": \"<terms-to-search>\"\n}",
      "tokenEstimate": 23
    },
    {
      "language": "json",
      "section": "Syntax",
      "content": "{\n  \"$search\": {\n    \"span\": {\n      \"contains\": {\n        \"spanToReturn\": \"inner\"|\"outer\",\n        \"little\": { <positional-or-term-operator-specification> },\n        \"big\": { <positional-or-term-operator-specification> }\n      }\n    }\n  }\n}",
      "tokenEstimate": 65
    },
    {
      "language": "javascript",
      "section": "Example",
      "content": "db.movies.aggregate([\n  {\n    \"$search\": {\n      \"span\": {\n        \"contains\": {\n          \"spanToReturn\": \"outer\",\n          \"little\": {\n            \"term\": {\n              \"path\": \"title\",\n              \"query\": \"train\"\n            }\n          },\n          \"big\": {\n            \"near\": {\n              \"clauses\": [\n                {\n                  \"term\": {\n                    \"path\": \"title\",\n                    \"query\": \"great\"\n                  }\n                },\n                {\n                  \"term\": {\n                    \"path\": \"title\",\n                    \"query\": \"robbery\"\n                  }\n                }\n              ],\n              \"slop\": 5\n            }\n          }\n        }\n      }\n    }\n  },\n  {\n    \"$limit\": 5\n  },\n  {\n    \"$project\": {\n      \"_id\": 0,\n      \"title\": 1\n    }\n  }\n])",
      "tokenEstimate": 184
    },
    {
      "language": "shell",
      "section": "Example",
      "content": "[\n  { title: 'The Great Train Robbery' },\n  { title: 'The Great Train Robbery' },\n  { title: \"The Great St. Trinian's Train Robbery\" }\n]",
      "tokenEstimate": 44
    },
    {
      "language": "json",
      "section": "Syntax",
      "content": "{\n  \"$search\": {\n    \"span\": {\n      \"first\": {\n        \"endPositionLte\": <term-position>,\n        \"operator\": { <span-positional-or-term-operator-specification> },\n        \"score\": { <score-options> }\n      }\n    }\n  }\n}",
      "tokenEstimate": 60
    },
    {
      "language": "javascript",
      "section": "Example",
      "content": "db.movies.aggregate([\n  {\n    \"$search\": {\n      \"span\": {\n        \"first\": {\n          \"endPositionLte\": 2,\n          \"operator\": {\n            \"term\": {\n              \"path\": \"title\",\n              \"query\": \"dance\"\n            }\n          }\n        }\n      }\n    }\n  },\n  {\n    \"$limit\": 5\n  },\n  {\n    \"$project\": {\n      \"_id\": 0,\n      \"title\": 1\n    }\n  }\n])",
      "tokenEstimate": 104
    },
    {
      "language": "json",
