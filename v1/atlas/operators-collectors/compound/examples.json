  "codeBlocks": [
    {
      "language": "javascript",
      "section": "Syntax",
      "content": "{\n  $search: {\n    \"index\": <index name>, // optional, defaults to \"default\"\n    \"compound\": {\n      <must | mustNot | should | filter>: [ { <clauses> } ],\n      \"score\": <options>\n    }\n  }\n}",
      "tokenEstimate": 58
    },
    {
      "language": "javascript",
      "section": "Usage",
      "content": "[\n  {\n    $search: {\n      index: \"default\",\n      compound: {\n        filter: [\n          {\n            compound: {\n              should: [\n                {\n                  equals: {\n                    path: \"accommodates\",\n                    value: 2\n                  }\n                },\n                {\n                  range: {\n                    path: \"pricePerNight\",\n                    lte: 200\n                  }\n                }\n              ]\n            }\n          }\n        ]\n      }\n    }\n  }\n]",
      "tokenEstimate": 96
    },
