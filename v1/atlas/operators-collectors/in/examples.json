      "section": "Sample Queries",
      "content": "db.customers.aggregate([\n  {\n    \"$search\": {\n      \"compound\": {\n        \"must\": [{\n          \"in\": {\n            \"path\": \"name\",\n            \"value\": [\"james sanchez\", \"jennifer lawrence\"]\n          }\n        }],\n        \"should\": [{\n          \"in\": {\n            \"path\": \"_id\",\n            \"value\": [ObjectId(\"5ca4bbcea2dd94ee58162a72\"), ObjectId(\"5ca4bbcea2dd94ee58162a91\")]\n          }\n        }]\n      }\n    }\n  },\n  {\n    \"$limit\": 5\n  },\n  {\n    \"$project\": {\n      \"_id\": 1,\n      \"name\": 1,\n      \"score\": { $meta: \"searchScore\" }\n    }\n  }\n])",
