    {
      "language": "json",
      "section": "Sample Queries",
      "content": "db.customers.aggregate([\n  {\n    \"$search\": {\n      \"in\": {\n        \"path\": \"accounts\",\n        \"value\": [371138, 371139, 371140]\n      }\n    }\n  },\n  {\n    \"$project\": {\n      \"_id\": 0,\n      \"name\": 1,\n      \"accounts\": 1\n    }\n  }\n])",
