  "codeBlocks": [
    {
      "language": "json",
      "section": "Syntax",
      "content": "{\n  $search: {\n    \"index\": <index name>, // optional, defaults to \"default\"\n    \"in\": {\n      \"path\": \"<field-to-search>\",\n      \"score\": <options>,\n      \"value\": <single-or-array-of-values-to-search>\n    }\n  }\n}",
      "tokenEstimate": 61
    },
    {
      "language": "json",
      "section": "Sample Index",
      "content": "{\n  \"mappings\": {\n    \"index\": \"default\",\n    \"dynamic\": true,\n    \"fields\": {\n      \"name\": {\n        \"normalizer\": \"lowercase\",\n        \"type\": \"token\"\n      }\n    }\n  }\n}",
      "tokenEstimate": 53
    },
    {
      "language": "json",
      "section": "Sample Queries",
      "content": "db.customers.aggregate([\n  {\n    \"$search\": {\n      \"in\": {\n        \"path\": \"birthdate\",\n        \"value\": [ISODate(\"1977-03-02T02:20:31.000+00:00\"), ISODate(\"1977-03-01T00:00:00.000+00:00\"), ISODate(\"1977-05-06T21:57:35.000+00:00\")]\n      }\n    }\n  },\n  {\n    \"$project\": {\n      \"_id\": 0,\n      \"name\": 1,\n      \"birthdate\": 1\n    }\n  }\n])",
      "tokenEstimate": 134
    },
    {
      "language": "json",
      "section": "Sample Queries",
      "content": "[\n  {\n    name: 'Elizabeth Ray',\n    birthdate: ISODate(\"1977-03-02T02:20:31.000Z\")\n  },\n  {\n    name: 'Brad Cardenas',\n    birthdate: ISODate(\"1977-05-06T21:57:35.000Z\")\n  }\n]",
      "tokenEstimate": 71
