{
  "path": "atlas/sample-weather",
  "product": "atlas",
  "title": "Sample Weather Dataset",
  "sections": [
    {
      "heading": "Collections",
      "headingLevel": 2,
      "body": "This database contains a single collection called `data`.\n\nThe `sample_weatherdata.data` collection contains all of the weather\nreports in the dataset. Each document in the collection represents a\nsingle weather report. The various weather observations within the\ndocument typically exist in embedded objects.",
      "codeBlocks": []
    },
    {
      "heading": "Indexes",
      "headingLevel": 3,
      "body": "The `sample_weatherdata.data` collection contains the following indexes:\n\n| Name   | Index          | Description                          |\n| ------ | -------------- | ------------------------------------ |\n| \\_id\\_ | \\{ \"\\_id\": 1 } | Primary key index on the \\_id field. |",
      "codeBlocks": []
    },
