      "language": "json",
      "section": "Define the Index for the dateFacet Type",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": true|false,\n    \"fields\": {\n      \"<field-name>\": {\n        \"type\": \"knnVector\",\n        \"dimensions\": <number-of-dimensions>,\n        \"similarity\": \"euclidean | cosine | dotProduct\"\n      }\n    }\n  }\n}",
      "tokenEstimate": 68
    },
    {
      "language": "json",
      "section": "Try an Example for the dateFacet Type",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": true,\n    \"fields\": {\n      \"plot_embedding\": {\n        \"type\": \"knnVector\",\n        \"dimensions\": 1536,\n        \"similarity\": \"euclidean\"\n      }\n    }\n  }\n}",
      "tokenEstimate": 57
    },
    {
      "language": "json",
      "section": "Migrate to vector Type",
