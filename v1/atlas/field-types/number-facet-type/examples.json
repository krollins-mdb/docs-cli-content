      "language": "json",
      "section": "Try an Example for the dateFacet Type",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": false,\n    \"fields\": {\n      \"year\": {\n        \"type\": \"numberFacet\"\n      }\n    }\n  }\n}",
      "tokenEstimate": 39
    },
    {
      "language": "json",
      "section": "Try an Example for the dateFacet Type",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": false,\n    \"fields\": {\n      \"year\": [\n        {\n          \"type\": \"numberFacet\"\n        },\n        {\n          \"type\": \"number\"\n        }\n      ]\n    }\n  }\n}",
