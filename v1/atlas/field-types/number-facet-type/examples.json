      "language": "json",
      "section": "Define the Index for the dateFacet Type",
      "content": "{\n  \"mappings\": {\n    \"dynamic\": true|false,\n    \"fields\": {\n      \"<field-name>\": {\n        \"type\": \"numberFacet\",\n        \"representation\": \"int64|double\",\n        \"indexIntegers\": true|false,\n        \"indexDoubles\": true|false\n      }\n    }\n  }\n}",
      "tokenEstimate": 73
    },
