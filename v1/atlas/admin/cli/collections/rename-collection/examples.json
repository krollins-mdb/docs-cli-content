      "content": "\"databases\" : [\n  {\n    \"name\": \"multiCollDB\",\n    \"collections\": [\n      {\n        \"name\": \"air_airlines\",\n        \"dataSources\": [{\n          \"storeName\" : \"egS3Store\",\n          \"path\" : \"egData/air_airlines.json\"\n        }]\n      },\n      {\n        \"name\": \"airbnb\",\n        \"dataSources\": [{\n          \"storeName\" : \"sampleS3Store\",\n          \"path\" : \"json/airbnb/*\"\n        }]\n      },\n      {\n        \"name\": \"weather\",\n        \"dataSources\": [{\n          \"storeName\" : \"sampleS3Store\",\n          \"path\" : \"json/weather/*\"\n        }]\n      }\n    ]\n  }\n]",
